# Copy to .env and fill in keys. Anything unset is treated as disabled.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=
# Google's OpenAI-compatible endpoint (preferred for provider parity):
GOOGLE_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: any OpenAI-compatible endpoint (Groq, Together, vLLM, Ollama, LM Studio, OpenRouter, Z.ai, ...)
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
